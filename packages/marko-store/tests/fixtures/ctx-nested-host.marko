import StoreProvider from '../../src/tags/store-provider.marko'
import StoreSelector from '../../src/tags/store-selector.marko'

// Two providers nested with DISTINCT keys. A child reads the outer bundle by key "outer"
// and the inner bundle by key "inner". (Two providers under the SAME key throw the
// duplicate guard — see ctx-dup-provider-host; distinct keys coexist.)
export interface Input {
  outer: any
  inner: any
}

<StoreProvider key="outer" value=() => ({ app: input.outer })>
  <StoreProvider key="inner" value=() => ({ section: input.inner })>
    <StoreSelector/appCount key="outer" context=(c: any) => c.app selector=(s: any) => s.count/>
    <StoreSelector/sectionCount key="inner" context=(c: any) => c.section selector=(s: any) => s.count/>
    <div data-testid='app'>${appCount}</div>
    <div data-testid='section'>${sectionCount}</div>
  </StoreProvider>
</StoreProvider>
