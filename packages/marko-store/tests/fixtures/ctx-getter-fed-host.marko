import StoreProvider from '../../src/tags/store-provider.marko'
import StoreSelector from '../../src/tags/store-selector.marko'
import StoreContext from '../../src/tags/store-context.marko'
export interface Input { store: any }
<StoreProvider value=() => ({ counter: input.store })>
  <StoreContext/ctx/>
  <StoreSelector/count from=() => (ctx() as any)?.counter ?? null selector=(s: any) => s.count/>
  <div data-testid='count'>${count}</div>
</StoreProvider>
