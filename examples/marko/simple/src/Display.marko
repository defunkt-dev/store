import { store } from './store'

export interface Input {
  animal: 'dogs' | 'cats'
}

// Re-renders only when state[animal] changes; an unrelated change won't re-render it.
<store-selector/count from=(() => store) selector=((s: { dogs: number; cats: number }) => s[input.animal])/>
<div>${input.animal}: ${count}</div>
