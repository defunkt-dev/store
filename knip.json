{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/marko-store": {
      "entry": [
        "src/tags/**/*"
      ],
      "ignoreDependencies": [
        "@marko/language-tools",
        "marko"
      ]
    },
    "packages/vue-store": {
      "ignoreDependencies": [
        "vue2",
        "vue2.7"
      ]
    },
    "packages/marko-store/e2e": {
      "entry": [
        "src/routes/**/+page.marko",
        "src/*.ts",
        "*.spec.ts"
      ],
      "ignore": [
        ".marko-run/**"
      ],
      "ignoreDependencies": [
        "@marko/language-tools"
      ]
    }
  },
  "ignoreWorkspaces": [
    "examples/**"
  ],
  "ignore": [
    "packages/store/src/signal.ts"
  ]
}
